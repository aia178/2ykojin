<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8FFE673"
    tools:context=".NewGoalActivity">

    <!-- ヘッダー -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="24dp">

            <!-- タイトルと戻るボタンを横並びに -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/badge_background"
                    android:src="@drawable/ic_arrow_back"
                    android:contentDescription="@string/btn_back"
                    android:scaleType="centerInside"
                    android:padding="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/title_new_goal"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_centerVertical="true"
                    android:paddingStart="56dp"
                    android:paddingEnd="56dp" />
            </RelativeLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- メインコンテンツ -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerCard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- タブレイアウト -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    app:tabIndicatorColor="#FFC107"
                    app:tabIndicatorHeight="3dp"
                    app:tabTextColor="#757575"
                    app:tabSelectedTextColor="#FFC107"
                    app:tabMode="fixed"
                    app:tabGravity="fill">

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_rakuten_search" />

                    <com.google.android.material.tabs.TabItem
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_custom_goal" />
                </com.google.android.material.tabs.TabLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 楽天検索タブの内容 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/rakutenSearchCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_search_product"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <!-- 検索フィールド -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/hint_search_product"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#FFC107"
                        app:endIconMode="clear_text"
                        app:startIconDrawable="@android:drawable/ic_menu_search">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSearchProduct"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 検索ボタン -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSearch"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/btn_search"
                        android:textSize="16sp"
                        app:backgroundTint="#FFC107"
                        android:textColor="#FFFFFF" />

                    <!-- 検索結果リスト -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="@string/label_search_results"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <!-- 追加: ローディング -->
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressSearch"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:layout_gravity="center_horizontal"
                        android:visibility="gone" />

                    <!-- 追加: 空表示 -->
                    <LinearLayout
                        android:id="@+id/stateEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="検索結果がありません"
                            android:textColor="#757575"
                            android:textSize="14sp"
                            android:paddingTop="4dp" />
                    </LinearLayout>

                    <!-- 追加: エラー表示 -->
                    <LinearLayout
                        android:id="@+id/stateError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="通信エラーが発生しました"
                            android:textColor="#757575"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRetry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="再試行"
                            style="@style/Widget.Material3.Button.FilledTonalButton" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSearchResults"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:minHeight="200dp"
                        android:clipToPadding="false"
                        tools:listitem="@layout/item_product" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- カスタム目標タブの内容 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/customGoalCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_custom_goal_info"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <!-- 目標名入力 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/hint_goal_name"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#FFC107">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etGoalName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 目標金額入力 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:hint="@string/hint_target_amount"
                        app:boxBackgroundColor="#FFFFFF"
                        app:boxStrokeColor="#FFC107"
                        app:prefixText="¥">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTargetAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 画像選択ボタン（オプション） -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectImage"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/btn_select_image"
                        android:textSize="16sp"
                        app:strokeColor="#FFC107"
                        app:strokeWidth="2dp"
                        android:textColor="#FFC107"
                        app:icon="@android:drawable/ic_menu_gallery"
                        app:iconGravity="start" />

                    <!-- 選択された画像プレビュー -->
                    <ImageView
                        android:id="@+id/ivImagePreview"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="16dp"
                        android:scaleType="centerCrop"
                        android:background="#F5F5F5"
                        android:visibility="gone"
                        android:contentDescription="@string/image_preview_description" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 保存ボタン -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/btn_save_goal"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#FFC107"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
