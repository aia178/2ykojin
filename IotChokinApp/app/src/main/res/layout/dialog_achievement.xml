<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="16dp"
    android:layout_margin="24dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- 達成した商品画像 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="160dp"
            android:layout_height="160dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/ivAchievedProduct"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="達成した商品画像"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- お祝いメッセージ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉 おめでとうございます！ 🎉"
            android:textSize="18sp"
            android:textColor="#FF9800"
            android:layout_marginBottom="8dp"/>

        <!-- 達成メッセージ -->
        <TextView
            android:id="@+id/tvAchievementMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="目標金額に到達しました！！"
            android:textColor="#FFC107"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- 達成した目標名 -->
        <TextView
            android:id="@+id/tvAchievedGoalName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="商品名"
            android:textColor="#424242"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

        <!-- 購入ボタン（楽天商品用） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToPurchase"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="購入ページへ"
            app:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            app:cornerRadius="28dp"
            android:textSize="16sp"
            android:visibility="gone"/> <!-- 初期は非表示 -->

        <!-- 閉じるボタン（共通） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseDialog"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="閉じる"
            app:backgroundTint="#757575"
            android:textColor="#FFFFFF"
            app:cornerRadius="28dp"
            android:textSize="16sp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>